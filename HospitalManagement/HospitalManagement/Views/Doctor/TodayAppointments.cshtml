<style>
    .table-card {
        width: 100%;
        margin: 0; /* remove outer spacing */
        padding: 0px; /* reduce inner gap */
        border-radius: 0px;
        background: rgba(255,255,255,.95);
        backdrop-filter: blur(8px);
        box-shadow: 0 12px 28px rgba(0,0,0,.18);
    }

        /* subtle hover lift */
        .table-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 30px 70px rgba(0,0,0,.25), 0 0 0 1px rgba(255,255,255,.7) inset;
        }

    /* HEADER */
    .custom-head th {
        background: linear-gradient(135deg,#3b82f6,#2563eb);
        color: white;
        border: none;
        padding: 14px;
    }

    /* ROW HOVER EFFECT */
    tbody tr {
        transition: .25s;
        cursor: pointer;
    }

        tbody tr:hover {
            transform: scale(1.05);
            background: #f8fbff;
            box-shadow: 0 8px 18px rgba(0,0,0,.15);
            z-index: 2;
            position: relative;
        }

    /* ===== SEARCH BAR ===== */
    .neo-search {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        height: 48px;
        padding: 6px;
        border-radius: 40px;
        background: linear-gradient(135deg,#1e3a8a,#1d4ed8);
        box-shadow: 0 10px 25px rgba(30,64,175,.25);
        transition: .35s;
    }

        .neo-search:hover {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 14px 35px rgba(37,99,235,.35);
        }

        .neo-search:focus-within {
            box-shadow: 0 0 0 2px #93c5fd,0 14px 40px rgba(37,99,235,.45);
        }

    /* icon */
    .search-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e40af;
        font-size: 16px;
    }

    /* input */
    .neo-search input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        color: white;
        padding: 0 12px;
    }

        .neo-search input::placeholder {
            color: rgba(255,255,255,.7);
        }

    

    body {
        background: linear-gradient(120deg,#c7d2fe,#dbeafe,#bfdbfe,#c7d2fe);
        background-size: 400% 400%;
        animation: gradientFlow 14s ease infinite;
        overflow-x: hidden;
    }

    @@keyframes gradientFlow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }


    /* ===============================
           STRONG GLOW ORBS
        ================================ */

    body::before,
    body::after {
        content: "";
        position: fixed;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        filter: blur(120px);
        z-index: -1;
    }

    /* blue glow */
    body::before {
        background: radial-gradient(circle,#2563eb,#1d4ed800 70%);
        top: -180px;
        left: -160px;
        animation: float1 18s linear infinite;
    }

    /* purple glow */
    body::after {
        background: radial-gradient(circle,#7c3aed,#6d28d900 70%);
        bottom: -200px;
        right: -180px;
        animation: float2 22s linear infinite;
    }

    @@keyframes float1 {
        0% {
            transform: translate(0,0)
        }

        50% {
            transform: translate(220px,130px)
        }

        100% {
            transform: translate(0,0)
        }
    }

    @@keyframes float2 {
        0% {
            transform: translate(0,0)
        }

        50% {
            transform: translate(-220px,-150px)
        }

        100% {
            transform: translate(0,0)
        }
    }


