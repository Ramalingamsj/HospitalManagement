@model List<HospitalManagement.ViewModels.DoctorAppointmentVM>
@{
    ViewData["Title"] = "Today's Appointments";
    Layout = "~/Views/Shared/_Doctor.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold">Doctor Appointments</h2>
            <small class="text-muted">
                Manage consultations, medicines and lab tests
            </small>
        </div>
    </div>

</div>




<!-- TABLE -->
<div class="table-card">

    <table class="table table-hover table-bordered align-middle mb-0">

        <thead class="text-center custom-head">
            <tr>
                <th>Profile</th>
                <th>Token</th>
                <th>Patient</th>
                <th>Gender</th>
                <th>Contact</th>
                <th>Time</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody class="text-center">
             @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                
                    <td class="text-center">
                        <div class="avatar-circle">
                            @item.PatientName.Substring(0, 1).ToUpper()
                        </div>
                    </td>
                   

                    <td>@item.TokenNo</td>
                    <td>@item.PatientName</td>
                    <td>@item.Gender</td>
                    <td>@item.Contact</td>
                    <td>@item.SlotTime</td>

                    <td>
                        @if (item.StatusName == "Completed")
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@item.StatusName</span>
                        }
                    </td>

                    <td>

                        @if (item.StatusName != "Completed")
                        {
                            <button class="btn btn-outline-primary btn-sm openModal"
                                    data-id="@item.AppointmentId">
                                <i class="bi bi-clipboard2-pulse"></i> Consult
                            </button>
                                <button class="btn btn-outline-secondary btn-sm viewHistoryBtn"
                                        data-patientid="@item.PatientId">
                                    <i class="bi bi-clock-history"></i> History
                                </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm openMedicineModal"
                                    data-id="@item.AppointmentId">
                                <i class="bi bi-capsule"></i> Medicine
                            </button>

                            <button class="btn btn-outline-info btn-sm openLabModal"
                                    data-id="@item.AppointmentId">
                                <i class="bi bi-eyedropper"></i> Lab
                            </button>
                                <button class="btn btn-info btn-sm"
                                        onclick="loadLabResults(@item.AppointmentId)">
                                    View Lab Results
                                </button>

                        }

                    </td>

                </tr>
            }
            }
            else
            {
                <!-- Show message if no records -->
                <tr>
                    <td colspan="8" class="text-center">
                        No patients For Today
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>
<div class="modal fade" id="labResultModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5>Lab Results</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Test</th>
                            <th>Result</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody id="labResultBody"></tbody>
                </table>
            </div>

        </div>
    </div>
</div>
<!-- HISTORY MODAL -->
<div class="modal fade" id="historyModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5>Patient Consultation History</h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="historySection">

                <div class="text-center text-muted">
                    Loading history...
                </div>

            </div>

        </div>
    </div>
</div>



<div class="modal fade" id="msgModal">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">

            <div class="modal-body text-center p-4">
                <h5 id="msgText" class="mb-3"></h5>
                <button class="btn btn-primary px-4"
                        data-bs-dismiss="modal">
                    OK
                </button>
            </div>

        </div>
    </div>
</div>
<script>
    function showMessage(message){
        document.getElementById("msgText").innerText = message;
        new bootstrap.Modal(document.getElementById("msgModal")).show();
    }
</script>
<script>
    function loadLabResults(id) {

        console.log("Loading results for:", id);

        $.get('@Url.Action("GetResults", "Doctor")', { appointmentId: id })
        .done(function (data) {

            let rows = "";

                data.forEach(r => {

        let resultText = r.result && r.result.trim() !== ""
            ? r.result
            : "<span class='text-warning fw-semibold'>Under Process</span>";

        rows += `<tr>
                    <td>${r.labtest_name}</td>
                    <td>${resultText}</td>
                    <td>${r.test_date ?? "-"}</td>
                 </tr>`;
    });

            document.getElementById("labResultBody").innerHTML = rows;

            new bootstrap.Modal(document.getElementById("labResultModal")).show();
        })
        .fail(function (err) {
            console.error(err.responseText);
            alert("Failed to load results");
        });
    }







        function loadHistory(patientId) {

        $("#historySection").html("<div class='text-center'>Loading...</div>");

        $.get("/Doctor/GetPatientHistory", { patientId: patientId }, function (data) {

            let html = "";

            if (!data || data.length === 0) {
                html = "<p class='text-muted'>No previous history found.</p>";
            }
            else {

                data.forEach(function (item) {

                    html += `
                        <div class="card mb-3 shadow-sm">
                            <div class="card-body">

                                <div class="d-flex justify-content-between">
                                    <h6 class="fw-bold text-primary">
                                        ${new Date(item.consultationDate).toLocaleDateString()}
                                    </h6>
                                </div>

                                <p><strong>Symptoms:</strong> ${item.symptoms ?? "-"}</p>
                                <p><strong>Diagnosis:</strong> ${item.diagnosis ?? "-"}</p>
                                <p><strong>Doctor Notes:</strong> ${item.doctorNotes ?? "-"}</p>

                                <hr/>

                                <p><strong>Medicine:</strong> ${item.medicineName ?? "-"}</p>
                                <p><strong>Lab Test:</strong> ${item.labTestName ?? "-"}</p>
                                <p><strong>Result:</strong> ${item.labResult ?? "-"}</p>

                            </div>
                        </div>
                    `;
                });
            }

            $("#historySection").html(html);

        }).fail(function () {
            $("#historySection").html("<p class='text-danger'>Failed to load history.</p>");
        });

        new bootstrap.Modal(document.getElementById("historyModal")).show();
    }
</script>
