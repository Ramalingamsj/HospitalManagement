<!-- CONSULTATION MODAL -->
<div class="modal fade" id="consultationModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" asp-action="AddConsultation" id="consultForm">

                <!-- HEADER -->
                <div class="modal-header bg-primary text-white">
                    <h5>Add Consultation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <input type="hidden" name="AppointmentId" id="appointmentId" />

                    <!-- Symptoms -->
                    <div class="mb-3">
                        <label class="fw-semibold">Symptoms *</label>
                        <textarea name="Symptoms" id="symptoms" class="form-control"></textarea>
                        <small class="text-danger validation-msg" id="symptomsError"></small>
                    </div>

                    <!-- Diagnosis -->
                    <div class="mb-3">
                        <label class="fw-semibold">Diagnosis *</label>
                        <textarea name="Diagnosis" id="diagnosis" class="form-control"></textarea>
                        <small class="text-danger validation-msg" id="diagnosisError"></small>
                    </div>

                    <!-- Doctor Notes -->
                    <div class="mb-3">
                        <label class="fw-semibold">Doctor Notes *</label>
                        <textarea name="DoctorNotes" id="doctorNotes" class="form-control"></textarea>
                        <small class="text-danger validation-msg" id="notesError"></small>
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">
                        Save Consultation
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const form = document.getElementById("consultForm");

        const symptoms = document.getElementById("symptoms");
        const diagnosis = document.getElementById("diagnosis");
        const doctorNotes = document.getElementById("doctorNotes");

        const fields = [
            { input: symptoms, errorId: "symptomsError", name: "Symptoms" },
            { input: diagnosis, errorId: "diagnosisError", name: "Diagnosis" },
            { input: doctorNotes, errorId: "notesError", name: "Doctor Notes" }
        ];

        const validPattern = /^[a-zA-Z0-9\s.,()-]+$/;

        function showError(input, errorId, message) {
            document.getElementById(errorId).innerText = message;
            input.classList.add("is-invalid");
        }

        function clearError(input, errorId) {
            document.getElementById(errorId).innerText = "";
            input.classList.remove("is-invalid");
        }
            function validateField(fieldObj) {

        let rawValue = fieldObj.input.value;
        let value = rawValue.trim();

        // Should not start with space
        if (rawValue.startsWith(" ")) {
            showError(fieldObj.input, fieldObj.errorId,
                fieldObj.name + " should not start with space.");
            return false;
        }

        // Required check
        if (value === "") {
            showError(fieldObj.input, fieldObj.errorId,
                fieldObj.name + " is required.");
            return false;
        }

        // Minimum 5 characters
        if (value.length < 5) {
            showError(fieldObj.input, fieldObj.errorId,
                fieldObj.name + " must contain at least 5 characters.");
            return false;
        }

        // Allowed characters check
        if (!validPattern.test(value)) {
            showError(fieldObj.input, fieldObj.errorId,
                "Invalid Input.");
            return false;
        }

        clearError(fieldObj.input, fieldObj.errorId);
        return true;
    }

        // Strict field control
        fields.forEach((field, index) => {

            field.input.addEventListener("blur", function () {
                if (!validateField(field)) {
                    field.input.focus();
                }
            });

            field.input.addEventListener("keydown", function (e) {

                if (e.key === "Enter") {
                    e.preventDefault();

                    if (validateField(field)) {
                        if (index + 1 < fields.length) {
                            fields[index + 1].input.focus();
                        }
                    } else {
                        field.input.focus();
                    }
                }
            });
        });

        diagnosis.addEventListener("focus", function () {
            if (!validateField(fields[0])) {
                symptoms.focus();
            }
        });

        doctorNotes.addEventListener("focus", function () {
            if (!validateField(fields[1])) {
                diagnosis.focus();
            }
        });

        form.addEventListener("submit", function (e) {

            let isValid = true;

            fields.forEach(field => {
                if (!validateField(field)) {
                    isValid = false;
                }
            });


            if (!isValid) {
                e.preventDefault();
            }
        });

    });
</script>
<!-- MEDICINE MODAL -->
<div class="modal fade" id="medicineModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" asp-action="AddMedicine">

                <div class="modal-header bg-success text-white">
                    <h5>Add Medicine</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="AppointmentId" id="medAppointmentId" />

                    <div class="mb-3">
                        <label>Medicine</label>
                        <select name="MedicineId" class="form-control" required>
                            <option value="">-- Select Medicine --</option>
                            @foreach (var m in ViewBag.Medicines)
                            {
                                <option value="@m.MedicineId">@m.MedicineName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Frequency (per day)</label>
                        <input type="number"
                               name="Frequency"
                               class="form-control"
                               required
                               min="1"
                               max="4"
                               oninput="if(this.value>4)this.value=4;">
                    </div>

                    <div class="mb-3">
                        <label>Duration (days)</label>
                        <input type="number"
                               name="DurationDays"
                               class="form-control"
                               required
                               min="1"
                               max="30"
                               oninput="if(this.value>30)this.value=30;">
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Add Medicine</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>

            </form>

        </div>
    </div>
</div>



<!-- LAB TEST MODAL -->
<div class="modal fade" id="labTestModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" asp-action="AddLabTest">

                <div class="modal-header bg-info text-white">
                    <h5>Add Lab Test</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="AppointmentId" id="labAppointmentId" />

                    <div class="mb-3">
                        <label>Lab Test</label>
                        <select name="LabTestId" class="form-control" required>
                            <option value="">-- Select Test --</option>
                            @foreach (var t in ViewBag.LabTests)
                            {
                                <option value="@t.LabTestId">@t.TestName</option>
                            }
                        </select>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Add Test</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>

            </form>

        </div>
    </div>
</div>
@if (TempData["Success"] != null)
{
