<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Prevent browser caching after logout -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>@ViewData["Title"] - Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HospitalManagement.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg fixed-top blue-nav">
        <div class="container-fluid">

            <!-- Title -->
            <span class="navbar-brand fw-bold logo-text">
                Receptionist Dashboard
            </span>

            <!-- Right Side -->
            <div class="ms-auto d-flex align-items-center gap-3">

                <!-- Username -->
              

                <!-- Logout -->
                <form asp-controller="Logins" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn logout-btn btn-sm">
                        Logout
                    </button>
                </form>

            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            © @DateTime.Now.Year - Hospital Management System
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
<style>

    /* ===============================
           BODY OFFSET FOR FIXED NAVBAR
        =================================*/
    body {
        padding-top: 70px;
    }


    /* ===============================
           GLASS NAVBAR (PREMIUM)
        =================================*/
    .blue-nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1030; /* FIXED VALUE */

        background: linear-gradient( 135deg, rgba(37,99,235,.65), rgba(37,99,235,.45) );
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid rgba(255,255,255,.35);
        box-shadow: 0 10px 32px rgba(0,0,0,.25);
        transition: .35s ease;
    }


        /* top glass highlight line */
        .blue-nav::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient( to right, transparent, rgba(255,255,255,.9), transparent );
        }


        /* animated shine sweep */
        .blue-nav::after {
            content: "";
            position: absolute;
            top: 0;
            left: -150%;
            width: 50%;
            height: 100%;
            background: linear-gradient( 120deg, transparent, rgba(255,255,255,.45), transparent );
            transform: skewX(-25deg);
            transition: 1.2s;
        }

        .blue-nav:hover::after {
            left: 150%;
        }


        /* hover depth */
        .blue-nav:hover {
            box-shadow: 0 14px 40px rgba(0,0,0,.35);
        }



    /* ===============================
           USERNAME BADGE
        =================================*/
    .user-pill {
        padding: 6px 18px;
        border-radius: 25px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.35);
        color: white;
        font-size: 14px;
        transition: .3s;
    }

        .user-pill:hover {
            background: white;
            color: #2563eb;
        }



    /* ===============================
           LOGOUT BUTTON (SOLID RED)
        =================================*/
    .logout-btn {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 4px 14px;
        font-weight: 600;
        transition: .25s;
    }

        .logout-btn:hover {
            background: #bb2d3b;
            transform: translateY(-1px);
        }

        .logout-btn:active {
            background: #a52834;
            transform: scale(.96);
        }
</style>