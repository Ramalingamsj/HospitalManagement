<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Prevent cache after logout -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>@ViewData["Title"] - Lab Technician Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg fixed-top blue-nav">
        <div class="container-fluid">

            <!-- Title -->
            <span class="navbar-brand fw-bold">
                Lab Technician Panel
            </span>

            <!-- Toggle -->
            <button class="navbar-toggler text-white"
                    data-bs-toggle="collapse"
                    data-bs-target="#nav">
                ☰
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse" id="nav">

                <ul class="navbar-nav ms-auto align-items-center gap-2">

                    <li class="nav-item">
                        <a class="nav-link nav-pill"
                           asp-controller="LabTechnician"
                           asp-action="Pending">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-pill"
                           asp-controller="LabTechnician"
                           asp-action="Bills">
                            Bills
                        </a>
                    </li>

                    <!-- Logout -->
                    <li class="nav-item ms-2">
                        <form asp-controller="Logins" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn logout-btn btn-sm">
                                Logout
                            </button>
                        </form>
                    </li>

                </ul>

            </div>
        </div>
    </nav>


    <!-- ================= PAGE CONTENT ================= -->
    <main class="container pb-3">
        @RenderBody()
    </main>


    <!-- ================= FOOTER ================= -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            © @DateTime.Now.Year - Hospital Management System
        </div>
    </footer>


    <!-- ================= SCRIPTS ================= -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>


<style>

    /* ===== FLEX LAYOUT ===== */
    html, body {
        height: 100%;
    }

    body {
        padding-top: 70px;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    main {
        flex: 1;
    }

    footer {
        margin-top: auto;
    }


    /* ===== GLASS NAVBAR ===== */
    .blue-nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1030;
        background: linear-gradient(135deg,rgba(37,99,235,.65),rgba(37,99,235,.45));
        backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid rgba(255,255,255,.35);
        box-shadow: 0 10px 32px rgba(0,0,0,.25);
        transition: .35s;
    }

        /* shine line */
        .blue-nav::before {
            content: "";
            position: absolute;
            top: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient(to right,transparent,rgba(255,255,255,.9),transparent);
        }

        /* shine animation */
        .blue-nav::after {
            content: "";
            position: absolute;
            top: 0;
            left: -150%;
            width: 50%;
            height: 100%;
            background: linear-gradient(120deg,transparent,rgba(255,255,255,.45),transparent);
            transform: skewX(-25deg);
            transition: 1.2s;
        }

        .blue-nav:hover::after {
            left: 150%;
        }


    /* NAV PILLS */
    .nav-pill {
        color: white !important;
        padding: 6px 16px !important;
        border-radius: 20px;
        transition: .3s;
        font-weight: 500;
    }

        .nav-pill:hover {
            background: white;
            color: #2563eb !important;
        }


    /* LOGOUT BUTTON */
    .logout-btn {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 4px 14px;
        font-weight: 600;
        transition: .25s;
    }

        .logout-btn:hover {
            background: #bb2d3b;
            transform: translateY(-1px);
        }


    /* ===== ANIMATED BACKGROUND ===== */
    body {
        background: linear-gradient(120deg,#c7d2fe,#dbeafe,#bfdbfe,#c7d2fe);
        background-size: 400% 400%;
        animation: gradientFlow 14s ease infinite;
    }

    @@keyframes gradientFlow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

</style>