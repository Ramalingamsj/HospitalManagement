@model LoginModel
@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>

    /* BODY */
    body {
        margin: 0;
        height: 100vh;
        display: flex;
        font-family: 'Segoe UI',sans-serif;
    }

    /* LEFT PANEL */
    .left-panel {
        width: 55%;
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        background: linear-gradient(-45deg,#2563eb,#4f46e5,#06b6d4,#3b82f6);
        background-size: 400% 400%;
        animation: gradientMove 12s ease infinite;
    }

    @@keyframes gradientMove {
        0% {
            background-position: 0% 50%
        }

        50% {
            background-position: 100% 50%
        }

        100% {
            background-position: 0% 50%
        }
    }

    .left-content {
        max-width: 350px;
    }

        .left-content i {
            font-size: 70px;
            margin-bottom: 20px;
        }

        .left-content h1 {
            font-weight: 700;
        }

        .left-content p {
            opacity: .9;
        }

    /* RIGHT PANEL */
    .right-panel {
        width: 45%;
        background: #f8fafc;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* CARD */
    .login-card {
        width: 360px;
        padding: 40px;
        border-radius: 16px;
        background: white;
        box-shadow: 0 25px 60px rgba(0,0,0,.15);
    }

    /* TITLE */
    .title {
        font-weight: 700;
        text-align: center;
        margin-bottom: 30px;
    }

    /* INPUT */
    .input-box {
        position: relative;
        margin-bottom: 20px;
    }

        .input-box input {
            width: 100%;
            padding: 12px 14px 12px 42px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            outline: none;
            transition: .25s;
        }

            .input-box input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 3px rgba(37,99,235,.15);
            }

        .input-box i {
            position: absolute;
            left: 14px;
            top: 14px;
            color: #94a3b8;
        }

    /* BUTTON */
    .login-btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(45deg,#2563eb,#4f46e5);
        color: white;
        font-weight: 600;
        transition: .25s;
    }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(79,70,229,.35);
        }

    /* ERROR */
    .error {
        text-align: center;
        color: #dc2626;
        margin-top: 14px;
    }

    /* FOOTER */
    .footer {
        text-align: center;
        margin-top: 25px;
        font-size: 13px;
        color: #94a3b8;
    }

</style>

<!-- LEFT -->

<div class="left-panel">
    <div class="left-content">
        <i class="fa-solid fa-hospital"></i>
        <h1>Hospital System</h1>
        <p>Secure Staff Portal<br />Access Restricted to Authorized Users</p>
    </div>
</div>

<!-- RIGHT -->

<div class="right-panel">

    <div class="login-card">

        <h4 class="title">Sign In</h4>

        <form method="post">

            <div class="input-box">
                <i class="fa fa-user"></i>
                <input asp-for="Username" placeholder="Username">
            </div>
            <span asp-validation-for="Username" class="text-danger small"></span>


            <div class="input-box">
                <i class="fa fa-lock"></i>
                <input asp-for="Password" type="password" placeholder="Password">
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>


            <button class="login-btn mt-2">Login</button>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="error">
                    @TempData["ErrorMessage"]
                </div>
            }

        </form>

        <div class="footer">
            © @DateTime.Now.Year Hospital Management System
        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
