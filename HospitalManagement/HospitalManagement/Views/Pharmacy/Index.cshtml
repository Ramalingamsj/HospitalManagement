@model List<Medicine>

@{
    ViewData["Title"] = "Medicine Management";
}
@{
    Layout = "~/Views/Shared/_PharmacyLayout.cshtml";
}

<div class="container mt-4">

    <h3 class="text-primary mb-3">Medicine Inventory</h3>

    <!-- SUCCESS MESSAGE -->
    

    <!-- TOP BAR -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <input type="text"
               id="searchBox"
               class="form-control w-50"
               placeholder="Search medicine..."
               onkeyup="searchMedicine()" />

        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addModal">
            + Add Medicine
        </button>

    </div>

    <!-- TABLE -->
    <table class="table table-bordered table-hover shadow-sm">

        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Stock</th>
                <th>Price</th>
                <th width="150">Action</th>
            </tr>
        </thead>

        <tbody id="medTable">

            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">
                        No medicines available
                    </td>
                </tr>
            }
            else
            {
                foreach (var m in Model)
                {
                    <tr class="med-row">
                        <td class="fw-semibold">@m.MedicineName</td>
                        <td>@m.MedicineType</td>

                        <td>
                            @if (m.StockQuantity <= 10)
                            {
                                <span class="badge bg-danger">@m.StockQuantity</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@m.StockQuantity</span>
                            }
                        </td>

                        <td>₹ @m.Price</td>

                        <td>
                            <button class="btn btn-warning btn-sm w-100"
                                    onclick="setStock(@m.MedicineId,@m.StockQuantity)">
                                Update Stock
                            </button>
                        </td>
                    </tr>
                }
            }

        </tbody>
    </table>

    <div id="noResult"
         class="text-center text-danger fw-bold mt-2"
         style="display:none">
        No matching medicine found
    </div>

</div>

<!-- ================= ADD MEDICINE MODAL ================= -->

<div class="modal fade" id="addModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="Create" method="post" id="medicineForm">

                <div class="modal-header bg-primary text-white">
                    <h5>Add Medicine</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- Name -->
                    <label>Name *</label>
                    <input name="MedicineName"
                           id="medName"
                           class="form-control mb-1" />
                    <small class="text-danger error" id="nameErr"></small>

                    <!-- Type -->
                    <label>Type *</label>
                    <select name="MedicineType"
                            id="medType"
                            class="form-select mb-1">
                        <option value="">-- Select Type --</option>
                        <option>Tablet</option>
                        <option>Syrup</option>
                    </select>
                    <small class="text-danger error" id="typeErr"></small>

                    <!-- Description -->
                    <label>Description</label>
                    <input name="Description"
                           id="medDesc"
                           class="form-control mb-2" />

                    <!-- Stock -->
                    <label>Stock *</label>
                    <input name="StockQuantity"
                           id="medStock"
                           type="number"
                           min="0"
                           class="form-control mb-1" />
                    <small class="text-danger error" id="stockErr"></small>

                    <!-- Price -->
                    <label>Price *</label>
                    <input name="Price"
                           id="medPrice"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-control mb-1" />
                    <small class="text-danger error" id="priceErr"></small>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.getElementById("medicineForm")
    .addEventListener("submit", function(e){

        let valid = true;

        document.querySelectorAll(".error").forEach(el=>el.innerText="");

        let name = medName.value.trim();
        let type = medType.value;
        let stock = medStock.value;
        let price = medPrice.value;

        if(!name){
            nameErr.innerText="Medicine name is required";
            valid=false;
        }

        if(!type){
            typeErr.innerText="Select medicine type";
            valid=false;
        }

        if(stock==="" || stock<0){
            stockErr.innerText="Enter valid stock";
            valid=false;
        }

        if(price==="" || price<=0){
            priceErr.innerText="Enter valid price";
            valid=false;
        }

        if(!valid) e.preventDefault();
    });
</script>

<!-- ================= UPDATE STOCK MODAL ================= -->

<div class="modal fade" id="stockModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="UpdateStock" method="post">

                <div class="modal-header bg-warning">
                    <h5>Update Stock</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="id" id="medId" />

                    <label>New Stock</label>
                    <input type="number"
                           name="stock"
                           id="stockInput"
                           class="form-control"
                           required />
                </div>

                <div class="modal-footer">
                    <button class="btn btn-success">Update</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- ================= SCRIPT ================= -->

<script>

    function setStock(id, stock) {
        document.getElementById("medId").value = id;
        document.getElementById("stockInput").value = stock;
        new bootstrap.Modal(document.getElementById('stockModal')).show();
    }

    function searchMedicine() {

        let input = document.getElementById("searchBox").value.toLowerCase();
        let rows = document.querySelectorAll(".med-row");
        let visible = 0;

        rows.forEach(row => {

            let text = row.innerText.toLowerCase();

            if (text.includes(input)) {
                row.style.display = "";
                visible++;
            }
            else {
                row.style.display = "none";
            }
        });

        document.getElementById("noResult").style.display =
            visible === 0 ? "block" : "none";
    }

</script>
<style>

    /* ===============================
           SUPER VISIBLE GRADIENT
        ================================ */

    body {
        background: linear-gradient(120deg,#c7d2fe,#dbeafe,#bfdbfe,#c7d2fe);
        background-size: 400% 400%;
        animation: gradientFlow 14s ease infinite;
        overflow-x: hidden;
    }

    @@keyframes gradientFlow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }


    /* ===============================
           STRONG GLOW ORBS
        ================================ */

    body::before,
    body::after {
        content: "";
        position: fixed;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        filter: blur(120px);
        z-index: -1;
    }

    /* blue glow */
    body::before {
        background: radial-gradient(circle,#2563eb,#1d4ed800 70%);
        top: -180px;
        left: -160px;
        animation: float1 18s linear infinite;
    }

    /* purple glow */
    body::after {
        background: radial-gradient(circle,#7c3aed,#6d28d900 70%);
        bottom: -200px;
        right: -180px;
        animation: float2 22s linear infinite;
    }

    @@keyframes float1 {
        0% {
            transform: translate(0,0)
        }

        50% {
            transform: translate(220px,130px)
        }

        100% {
            transform: translate(0,0)
        }
    }

    @@keyframes float2 {
        0% {
            transform: translate(0,0)
        }

        50% {
            transform: translate(-220px,-150px)
        }

        100% {
            transform: translate(0,0)
        }
    }


    /* ===============================
           STRONG GRID VISIBILITY
        ================================ */

    html::after {
        content: "";
        position: fixed;
        inset: 0;
        background-image: linear-gradient(rgba(0,0,0,.09) 1px,transparent 1px), linear-gradient(90deg,rgba(0,0,0,.09) 1px,transparent 1px);
        background-size: 45px 45px;
        z-index: -2;
    }

    .neon-btn {
        border: 2px solid #3b82f6;
        color: #3b82f6;
        background: transparent;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 25px;
        transition: .3s;
    }

        .neon-btn:hover {
            background: #3b82f6;
            color: white;
            box-shadow: 0 0 15px #3b82f6, 0 0 30px #3b82f6;
        }
</style>