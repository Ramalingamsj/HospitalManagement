@model List<BillList>

@{
    ViewData["Title"] = "Bills";
}
@{
    Layout = "~/Views/Shared/_PharmacyLayout.cshtml";
}

<div class="container mt-4">

    <h3 class="mb-3 text-primary">Generated Bills</h3>

    <table class="table table-bordered table-hover shadow">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Patient</th>
                <th>Consultation</th>
                <th>Total</th>
                <th>Date</th>
                <th width="130">Action</th>
            </tr>
        </thead>

        <tbody>

            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        No bills generated
                    </td>
                </tr>
            }
            else
            {
                foreach (var bill in Model)
                {
                    <tr>
                        <td><strong>#@bill.BillId</strong></td>
                        <td>@bill.PatientName</td>
                        <td>#@bill.ConsultationId</td>
                        <td class="text-success fw-semibold">₹ @bill.TotalAmount</td>
                        <td>@bill.CreatedAt.ToString("dd MMM yyyy")</td>

                        <td>
                            <a asp-action="DownloadBill"
                               asp-route-id="@bill.ConsultationId"
                               class="btn btn-outline-primary btn-sm w-100">
                                Download PDF
                            </a>
                        </td>
                    </tr>
                }
            }

        </tbody>

    </table>
</div>
<style>

    /* ===============================
           SUPER VISIBLE GRADIENT
        ================================ */

    body {
        background: linear-gradient(120deg,#c7d2fe,#dbeafe,#bfdbfe,#c7d2fe);
        background-size: 400% 400%;
        animation: gradientFlow 14s ease infinite;
        overflow-x: hidden;
    }

    @@keyframes gradientFlow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }


    /* ===============================
           STRONG GLOW ORBS
        ================================ */

    body::before,
    body::after {
        content: "";
        position: fixed;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        filter: blur(120px);
        z-index: -1;
    }

    /* blue glow */
    body::before {
        background: radial-gradient(circle,#2563eb,#1d4ed800 70%);
        top: -180px;
        left: -160px;
        animation: float1 18s linear infinite;
    }

    /* purple glow */
    body::after {
        background: radial-gradient(circle,#7c3aed,#6d28d900 70%);
        bottom: -200px;
        right: -180px;
        animation: float2 22s linear infinite;
    }

    @@keyframes float1 {
        0% {
            transform: translate(0,0)
        }

        50% {
            transform: translate(220px,130px)
        }

        100% {
            transform: translate(0,0)
        }
    }

    @@keyframes float2 {
        0% {
            transform: translate(0,0)
        }

        50% {
            transform: translate(-220px,-150px)
        }

        100% {
            transform: translate(0,0)
        }
    }


    /* ===============================
           STRONG GRID VISIBILITY
        ================================ */

    html::after {
        content: "";
        position: fixed;
        inset: 0;
        background-image: linear-gradient(rgba(0,0,0,.09) 1px,transparent 1px), linear-gradient(90deg,rgba(0,0,0,.09) 1px,transparent 1px);
        background-size: 45px 45px;
        z-index: -2;
    }

    .neon-btn {
        border: 2px solid #3b82f6;
        color: #3b82f6;
        background: transparent;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 25px;
        transition: .3s;
    }

        .neon-btn:hover {
            background: #3b82f6;
            color: white;
            box-shadow: 0 0 15px #3b82f6, 0 0 30px #3b82f6;
        }
</style>